-})();
+/* Shared speech controls for 涔︽姤 (Books)
+   Engines:
+   - NativeTTS (Capacitor Foreground Service) -- Android APK, background-safe
+   - Web Speech API                           -- browser / PWA fallback
+
+   Exposes:
+     window.BKSpeech.init({ getElements: () => [{el}], lang?: string })
+     window.BKSpeech.cancel()
+*/
+(function () {
+  'use strict';
+
+  function byId(id) { return document.getElementById(id); }
+
+  // 鈹€鈹€ 缁熶竴鏂囨湰澶勭悊绠￠亾锛堥€傞厤绾枃鏈?content锛夆攢鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
+  // isPlainText: 鑻ヤ负 true锛岃〃绀鸿緭鍏ュ凡鏄函鏂囨湰锛坺l-html锛夛紝涓嶅仛 HTML 娓呮礂
+  function processText(raw, isPlainText) {
+    var t = raw || '';
+
+    // 1) 鍩烘湰绌虹櫧鏁寸悊
+    t = t.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
+
+    if (!isPlainText) {
