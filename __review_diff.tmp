-    // -- Engine detection ---------------------------------------------------
-
-    function getNativeTTS() {
-      return window.Capacitor &&
-             window.Capacitor.Plugins &&
-             window.Capacitor.Plugins.NativeTTS &&
-             typeof window.Capacitor.Plugins.NativeTTS.speak === 'function'
