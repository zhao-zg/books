+
+/* 鈹€鈹€ 瑙︽懜浼樺寲 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
+/* 娑堥櫎 300ms 鐐瑰嚮寤惰繜 */
+a, button, [role="button"], input, select, textarea, .book-link, .series-tab, .nav-link, .bk-toc-chapter-item {
+  touch-action: manipulation;
+}
+
+/* 浼樺寲瑙︽懜楂樹寒鍙嶉 */
+.book-link, .series-tab, .nav-link, .bk-toc-chapter-item, .action-btn, .control-btn {
+  -webkit-tap-highlight-color: transparent;
+}
+
+/* 鈹€鈹€ 闃呰瑙嗗浘杩囨浮鍔ㄧ敾 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
+#app {
+  will-change: opacity;
+}
+#app.bk-view-enter {
+  opacity: 0;
+}
+#app.bk-view-enter-active {
+  opacity: 1;
+  transition: opacity 150ms ease-out;
+}
 """
         css_dir = os.path.join(self.output_dir, 'css')
         os.makedirs(css_dir, exist_ok=True)
